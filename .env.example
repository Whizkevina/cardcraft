# ─── Paystack ────────────────────────────────────────────────────────────────
# Get your keys from https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ─── Gmail SMTP ───────────────────────────────────────────────────────────────
# Use a Gmail App Password (NOT your Gmail login password)
# Enable: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── App URL ─────────────────────────────────────────────────────────────────
# Your deployed app URL (used for Paystack callback redirect)
APP_URL=https://your-domain.com

# ─── Session ─────────────────────────────────────────────────────────────────
# Change this to a long random string in production
SESSION_SECRET=change-this-to-a-long-random-secret-string
